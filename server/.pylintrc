[MASTER]
# Keep noise down from venv, caches, etc.
ignore=.venv,.pytest_cache,build,dist
ignore-patterns=^\.venv/|^\.pytest_cache/|^build/|^dist/
jobs=0
persistent=yes

py-version=3.10

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    import-outside-toplevel,
    too-many-arguments,
    too-many-branches,
    too-many-instance-attributes,
    too-many-lines,
    too-many-locals,
    too-many-positional-arguments,
    too-many-statements,
    too-few-public-methods,
    too-many-public-methods,
    line-too-long,
    # pytest fixtures shadow outer scope by design
    redefined-outer-name,
    # sys.path manipulation before imports in standalone-runnable test files
    wrong-import-position,
    # test files legitimately share boilerplate assertion patterns
    duplicate-code,

[REPORTS]
score=yes
output-format=text
reports=no

[EXCEPTIONS]
overgeneral-exceptions=builtins.Exception

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[IMPORTS]
known-standard-library=
known-third-party=pytest,pydantic,quart,discord
